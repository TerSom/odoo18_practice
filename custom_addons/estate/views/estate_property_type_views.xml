<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_propery_type_action" model="ir.actions.act_window">
        <field name="name">estate.propery.type</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_property_type_view_list" model="ir.ui.view">
        <field name="name">estae.property.type</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="estate_porpery_type_view_form" model="ir.ui.view">
        <field name="name">estate.porpery.type.view.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <header>
                        <div class="oe_button_box" name="button_box">
                            <button type="action" name="%(estate_property_offer_action)d" class="oe_stat_button" icon="fa-list">
                                <field name="offer_count" widget="statinfo" string="Offers"/>
                            </button>
                        </div>
                    </header>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Properties">
                            <field name="property_ids">
                                <form>
                                    <field name="name" />
                                    <field name="expected_price" />
                                    <field name="state" />
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
