<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="estate_property_offer_table">
        <table class="table">
            <thead>
                <tr>
                    <th>Price</th>
                    <th>Partner</th>
                    <th>Validity</th>
                    <th>Deadline</th>
                    <th>State</th>
                </tr>
            </thead>
            <tbody>
                <t t-set="offers" t-value="property.offer_ids"/>
                <tr t-foreach="offers" t-as="offer">
                    <td>
                        <span t-field="offer.price"/>
                    </td>
                    <td>
                        <span t-field="offer.partner_id"/>
                    </td>
                    <td>
                        <span t-field="offer.validity"/>
                    </td>
                    <td>
                        <span t-field="offer.date_deadline"/>
                    </td>
                    <td>
                        <span t-field="offer.status"/>
                    </td>
                </tr>
            </tbody>
        </table>
    </template>

    <template id="report_property_offers">
        <t t-foreach="docs" t-as="property">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>
                            <span t-field="property.name"/>
                        </h2>
                        <div>
                            <strong>Salesman: </strong>
                            <span t-field="property.salesperson_id" />
                        </div>
                        <div>
                            <strong>Expected Price: </strong>
                            <span t-field="property.expected_price"/>
                        </div>
                        <div>
                            <strong>Status: </strong>
                            <span t-field="property.state"/>
                        </div>
                        <t t-call="estate.estate_property_offer_table"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_salesman_property">
        <t t-foreach="docs" t-as="user">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h1>
                            <strong>Salesman</strong>
                            <span t-field="user.name" />
                        </h1>
                        <t t-foreach="user.property_ids" t-as="property">
                            <h1>
                                <span t-field="property.name"></span>
                            </h1>
                            <div>
                                <strong>Expected price :</strong>
                                <span t-field="property.expected_price"></span>
                            </div>
                            <div>
                                <strong>Status : </strong>
                                <spana t-field="property.state"></spana>
                            </div>
                            <t t-if="property.state != 'new'">
                                <t t-call="estate.estate_property_offer_table"/>
                            </t>
                            <t t-else="">
                                <p>No offers available sad :O</p>
                            </t>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>